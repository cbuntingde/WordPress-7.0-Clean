<?xml version="1.0"?>
<psalm name="WordPress 7.0"
    autoloader="vendor/autoload.php"
    cacheDirectory=".psalm/cache"
    reportFile=".psalm/report">
    <projectFiles>
        <directory name="wp-admin"/>
        <directory name="wp-includes"/>
        <ignoreDirectory name="vendor"/>
        <ignoreDirectory name="node_modules"/>
        <ignoreDirectory name="*/tests/*"/>
        <ignoreDirectory name="*/third-party/*"/>
        <ignoreDirectory name="*/php-ai-client/*"/>
    </projectFiles>
</psalm>